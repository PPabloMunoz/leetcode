# EditorConfig is awesome: https://editorconfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go files: Use tabs (required by gofmt)
[*.go]
indent_style = space
indent_size = 4
tab_width = 4

# Makefiles and Git configs require tabs
[Makefile]
indent_style = tab
